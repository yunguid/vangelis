{
  "version": 2,
  "installCommand": "cd sound-engine/frontend && npm ci",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "sound-engine/frontend/dist",
  "routes": [
    {
      "src": "/api/sound-catalog",
      "dest": "/api/sound-catalog.js"
    },
    {
      "src": "/api/phrase-loop",
      "dest": "/api/phrase-loop.js"
    },
    {
      "src": "/api/voice-phrase",
      "dest": "/api/voice-phrase.js"
    },
    {
      "src": "/api/status",
      "dest": "/api/status.js"
    },
    {
      "src": "/pkg/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/pkg/$1"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
